# ─── Environment ────────────────────────────────────────────────
# Set to "development" to enable debug logging and API docs
ENVIRONMENT=development

# ─── Server ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# In production, set this to your Vercel domain
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# ─── File Limits ────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_REQUEST=20

# ─── Temp Files ─────────────────────────────────────────────────
# How long converted files are kept (seconds)
FILE_TTL_SECONDS=600

# How often the cleanup task runs (seconds)
CLEANUP_INTERVAL_SECONDS=300

# Temp directory path (inside the container)
TEMP_DIR=/tmp/convertx

# ─── External Tools ─────────────────────────────────────────────
# Only change these if tools are in non-standard locations
LIBREOFFICE_PATH=libreoffice
TESSERACT_PATH=tesseract
